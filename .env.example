# ── LLM Provider (set at least one) ──────────────────────────────────────────
# Default: anthropic. Can also be: openai, openai-compat
# LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# OpenAI-compatible (Xiaomi MiMo, local LLMs, etc.)
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.example.com/v1

# Override default model (optional)
# LLM_MODEL=claude-sonnet-4-20250514

# ── Optional ──────────────────────────────────────────────────────────────────
# Faster HuggingFace downloads
HF_TOKEN=hf_...

# Access private YesWeHack programs
YWH_PAT=

# Access private HackerOne programs
H1_USER=
H1_TOKEN=
